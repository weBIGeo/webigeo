    "format": "webigeo/node-graph",
    "name": "snow_compute_graph",
    "nodes": [
        {
            "enabled": true,
            "name": "gpx_track_node",
            "settings": {
                "enable_caching": true,
                "file_path": ":/gpx/breite_ries.gpx"
            },
            "type": "GPXTrackNode"
        },
        {
            "enabled": true,
            "name": "height_decode_node",
            "settings": {
                "texture_usage": [
                    "CopySrc",
                    "CopyDst",
                    "TextureBinding",
                    "StorageBinding"
                ]
            },
            "type": "HeightDecodeNode"
        },
        {
            "enabled": true,
            "name": "normals_node",
            "settings": {
                "format": "RGBA8Unorm",
                "usage": [
                    "CopyDst",
                    "TextureBinding",
                    "StorageBinding"
                ]
            },
            "type": "ComputeNormalsNode"
        },
        {
            "enabled": true,
            "name": "overlay_node",
            "settings": {
                "copy": false
            },
            "type": "OverlayRenderNode"
        },
        {
            "enabled": true,
            "name": "request_height_node",
            "settings": {
                "file_extension": ".png",
                "tile_path": "https://alpinemaps.cg.tuwien.ac.at/tiles/at_dtm_alpinemaps/",
                "url_pattern": "ZXY"
            },
            "type": "RequestTilesNode"
        },
        {
            "enabled": true,
            "name": "select_tiles_node",
            "settings": {
                "zoomlevel": 15
            },
            "type": "SelectTilesNode"
        },
        {
            "enabled": true,
            "name": "snow_node",
            "settings": {
                "altitude_blend": 200,
                "altitude_variation": 200,
                "angle_blend": 0,
                "format": "RGBA8Unorm",
                "max_angle": 45,
                "min_altitude": 1000,
                "min_angle": 0,
                "usage": [
                    "CopySrc",
                    "CopyDst",
                    "TextureBinding",
                    "StorageBinding"
                ]
            },
            "type": "ComputeSnowNode"
        },
        {
            "enabled": true,
            "name": "stitch_node",
            "settings": {
                "stitch_inverted_y": true,
                "texture_format": "RGBA8Uint",
                "texture_usage": [
                    "CopySrc",
                    "CopyDst",
                    "TextureBinding",
                    "StorageBinding"
                ],
                "tile_has_border": true,
                "tile_size": [
                    65,
                    65
                ]
            },
            "type": "TileStitchNode"
        }
    ],
